# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Mock storage adapter dev sandbox — keep the dir + README, ignore content.
# PDFs and audio are committed so the demo reader/player works on Vercel.
/public/placeholder-content/*
!/public/placeholder-content/README.md
!/public/placeholder-content/*.pdf
!/public/placeholder-content/*.mp3

# pdfjs-dist runtime assets — copied from node_modules by the postinstall
# script (scripts/copy-pdf-assets.mjs). Don't commit; they regenerate on
# every `npm install` and must match the installed pdfjs-dist version.
/public/pdf.worker.min.mjs
/public/cmaps/
/public/standard_fonts/

.vercel
.env*.local

# Lighthouse audit output (regenerated locally)
/lighthouse-reports/
